{
  "manifest_version": 3,
  "name": "Randy — Recast SE Assistant",
  "version": "2.0.0",
  "description": "Voice assistant that listens during calls and answers Recast product questions on screen and aloud.",
  "action": {
    "default_title": "Randy — Recast SE Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["sidePanel", "scripting", "storage", "clipboardWrite"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
